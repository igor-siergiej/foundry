{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["shoppingo", "web"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Shoppingo Web",
  "uid": "shoppingo-web",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Static-asset requests (5m)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({container=~\"shoppingo-web.*\"} [5m]))", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Frontend errors (24h)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({container=~\"shoppingo-api.*\"} | json | source=\"frontend\" | level=\"error\" [24h]))", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Distinct clients (24h, by userAgent)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "count(count by (userAgent) (count_over_time({container=~\"shoppingo-api.*\"} | json | source=\"frontend\" | userAgent != \"\" [24h])))", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Rate-limit rejections (24h)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({container=~\"shoppingo-api.*\"} |~ \"Frontend logs rate limit exceeded\" [24h]))", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Frontend log volume by level",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "sum by (level) (rate({container=~\"shoppingo-api.*\"} | json | source=\"frontend\" [5m]))", "legendFormat": "{{level}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Nginx response volume (web container)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "sum by (stream) (rate({container=~\"shoppingo-web.*\"} [5m]))", "legendFormat": "{{stream}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Frontend errors over time",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "refId": "A", "expr": "sum(rate({container=~\"shoppingo-api.*\"} | json | source=\"frontend\" | level=\"error\" [5m]))", "legendFormat": "errors" },
        { "refId": "B", "expr": "sum(rate({container=~\"shoppingo-api.*\"} | json | source=\"frontend\" | level=\"warn\" [5m]))", "legendFormat": "warnings" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top frontend error messages (24h)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "refId": "A", "expr": "topk(10, sum by (message) (count_over_time({container=~\"shoppingo-api.*\"} | json | source=\"frontend\" | level=\"error\" [24h])))", "instant": true, "format": "table" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Web container CPU",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"shoppingo-web.*\"}[5m]))", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Web container memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (container_memory_usage_bytes{name=~\"shoppingo-web.*\"})", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Recent frontend errors (live)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "targets": [
        { "refId": "A", "expr": "{container=~\"shoppingo-api.*\"} | json | source=\"frontend\" | level=~\"error|warn\"" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}

{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["shoppingo", "api"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Shoppingo API",
  "uid": "shoppingo-api",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "AI images generated (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(shoppingo_images_generated_total[24h]))" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue" }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Image gen failures (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(shoppingo_image_generation_failures_total[24h]))" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Requests/sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(shoppingo_api_http_requests_total[5m]))" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "5xx rate (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(shoppingo_api_http_requests_total{status=~\"5..\"}[5m]))" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "red", "value": 0.1 }] } } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "AI images served (fresh vs cache)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "sum by (source) (rate(shoppingo_images_served_total[5m]))", "legendFormat": "{{source}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Image generation events",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "sum by (provider) (rate(shoppingo_images_generated_total[5m]))", "legendFormat": "generated {{provider}}" },
        { "refId": "B", "expr": "sum by (provider) (rate(shoppingo_image_generation_failures_total[5m]))", "legendFormat": "failed {{provider}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Requests by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "refId": "A", "expr": "sum by (status) (rate(shoppingo_api_http_requests_total[5m]))", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (all routes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(shoppingo_api_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(shoppingo_api_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(shoppingo_api_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top routes by traffic",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "refId": "A", "expr": "topk(10, sum by (route, method) (rate(shoppingo_api_http_requests_total[5m])))", "format": "table", "instant": true }
      ],
      "transformations": [{ "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "service": true } } }]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Top routes by p95 latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "refId": "A", "expr": "topk(10, histogram_quantile(0.95, sum by (le, route) (rate(shoppingo_api_http_request_duration_seconds_bucket[5m]))))", "format": "table", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "transformations": [{ "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "service": true } } }]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Container CPU",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"shoppingo-api.*\"}[5m]))", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Container memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (container_memory_usage_bytes{name=~\"shoppingo-api.*\"})", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Unauthorized attempts (from logs)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "targets": [
        { "refId": "A", "expr": "sum(rate({container=~\"shoppingo-api.*\"} |~ \"Unauthorized.*attempt\" [5m]))", "legendFormat": "unauthorized" }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Distinct userIds (24h, from logs)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "targets": [
        { "refId": "A", "expr": "count(count by (userId) (count_over_time({container=~\"shoppingo-api.*\"} | json | userId != \"\" [24h])))", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 15,
      "type": "logs",
      "title": "Recent errors",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 44 },
      "targets": [
        { "refId": "A", "expr": "{container=~\"shoppingo-api.*\"} | json | level=\"error\"" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
